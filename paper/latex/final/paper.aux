\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Baseline comparison with traffic-light coloring. The over-governed scenario (row\nonbreakingspace 3) reveals the key mismatch: the threshold classifier labels it \emph  {stable} (green) while the structural diagnostic correctly identifies a \emph  {limit cycle} (red).}}{6}{figure.caption.22}\protected@file@percent }
\newlabel{fig:baseline}{{5}{6}{Baseline comparison with traffic-light coloring. The over-governed scenario (row~3) reveals the key mismatch: the threshold classifier labels it \emph {stable} (green) while the structural diagnostic correctly identifies a \emph {limit cycle} (red)}{figure.caption.22}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Restraint Necessity: the growth-truncation oscillation (Property\nonbreakingspace \ref {prop:restraint}). When all gates in the template pass, VEIL corrections accumulate but are destroyed by truncation when the expression exceeds the node cap. The template then re-asserts high gatedness, restarting the cycle. This oscillation prevents convergence, proving that structural restraint (at least one holding gate) is necessary.}}{7}{figure.caption.24}\protected@file@percent }
\newlabel{fig:restraint}{{6}{7}{Restraint Necessity: the growth-truncation oscillation (Property~\ref {prop:restraint}). When all gates in the template pass, VEIL corrections accumulate but are destroyed by truncation when the expression exceeds the node cap. The template then re-asserts high gatedness, restarting the cycle. This oscillation prevents convergence, proving that structural restraint (at least one holding gate) is necessary}{figure.caption.24}{}}

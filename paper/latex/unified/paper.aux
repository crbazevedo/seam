\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Restraint Necessity: the growth-truncation oscillation (Property\nonbreakingspace \ref {prop:restraint}). When all gates in the template pass, VEIL corrections accumulate but are destroyed by truncation when the expression exceeds the node cap. The template then re-asserts high gatedness, restarting the cycle. This oscillation prevents convergence, proving that structural restraint (at least one holding gate) is necessary.}}{8}{figure.caption.22}\protected@file@percent }
\newlabel{fig:restraint}{{6}{8}{Restraint Necessity: the growth-truncation oscillation (Property~\ref {prop:restraint}). When all gates in the template pass, VEIL corrections accumulate but are destroyed by truncation when the expression exceeds the node cap. The template then re-asserts high gatedness, restarting the cycle. This oscillation prevents convergence, proving that structural restraint (at least one holding gate) is necessary}{figure.caption.22}{}}
